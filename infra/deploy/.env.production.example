# infra/deploy/.env.production.example
#
# Copy to infra/deploy/.env.production and fill in. The deploy scripts
# will read this if it exists, OR you can `source` it before running:
#   set -a && source infra/deploy/.env.production && set +a
#   bash infra/deploy/deploy-api.sh
#
# .env.production is gitignored — never commit it.

# ─── Project ──────────────────────────────────────────────────────────
PROJECT_ID=sincere-burner-475520-g7
REGION=us-central1

# ─── Supabase (same project as dev for now — see PRODUCTION_TODOS.md) ─
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public — gets baked into the web bundle at build time
VITE_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=

# ─── LLMs ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── ElevenLabs (voice + Scribe) ──────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── Cerebro (the platform) ───────────────────────────────────────────
CEREBRO_BASE_URL=https://shift-cerebro-production.up.railway.app

# ─── CORS / public origins ────────────────────────────────────────────
# Comma-separated list of allowed origins. MUST include the web service's
# public URL once domain mapping is done.
ALLOWED_ORIGINS=https://cl2-v2.agentescl2.com

# ─── (Optional) Sentry ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=production
