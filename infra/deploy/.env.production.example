# infra/deploy/.env.production.example
#
# Copy to infra/deploy/.env.production and fill in. The deploy scripts
# will read this if it exists, OR you can `source` it before running:
#   set -a && source infra/deploy/.env.production && set +a
#   bash infra/deploy/deploy-api.sh
#
# .env.production is gitignored — never commit it.

# ─── Project ──────────────────────────────────────────────────────────
PROJECT_ID=sincere-burner-475520-g7
REGION=us-central1

# ─── Supabase (same project as dev for now — see PRODUCTION_TODOS.md) ─
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public — gets baked into the web bundle at build time
VITE_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=

# ─── LLMs ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── ElevenLabs (voice + Scribe) ──────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── Cerebro (the platform) ───────────────────────────────────────────
CEREBRO_BASE_URL=https://shift-cerebro-production.up.railway.app

# ─── Bypass Cerebro proxy (TEMPORAL — ver locks/06-bypass-cerebro-temporal.md)
# El proxy Cerebro mangling responses post-tool_result (content:null random).
# Mientras no se arregle upstream, CL2 bypassa directo a OpenRouter.
# `deploy-api.sh` lee CL2_FORCE_CEREBRO_BYPASS=1 → al final del deploy hace
# `gcloud run services update --update-env-vars` sobreescribiendo CEREBRO_BASE_URL
# y CEREBRO_API_KEY con los valores de abajo. Las llamadas LLM van directo a
# OpenRouter sin pasar por el proxy.
# Cuando el upstream se arregle: poner CL2_FORCE_CEREBRO_BYPASS=0 y redeployear.
CL2_FORCE_CEREBRO_BYPASS=1
BYPASS_LLM_BASE_URL=https://openrouter.ai/api
BYPASS_LLM_API_KEY=

# ─── CORS / public origins ────────────────────────────────────────────
# ALLOWED_ORIGINS: CSV para el middleware cors(). Incluir TODOS los dominios
# desde los que el frontend pueda hacer requests al API (run.app + dominio
# bonito si está mapeado).
ALLOWED_ORIGINS=https://cl2-v2-web-u3rliii7wa-uc.a.run.app,https://cl2-v2.agentescl2.com

# PUBLIC_WEB_URL: dominio canónico del frontend, usado para generar links
# públicos (share de podcast, emails, etc.). Tiene que resolver en DNS de
# verdad. Si lo dejás vacío, deploy-api.sh hace fallback al primer
# ALLOWED_ORIGINS.
PUBLIC_WEB_URL=https://cl2-v2-web-u3rliii7wa-uc.a.run.app

# ─── (Optional) Sentry ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=production
