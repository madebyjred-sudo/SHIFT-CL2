# Shift CL2 — environment template
# Copy to .env.local for local dev, set in Railway for prod

# === Supabase (project: shift-cl2-prod) ===
NEXT_PUBLIC_SUPABASE_URL=https://romccykiucfltfdfatrx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Cerebro (Railway shared instance, tenant=cl2) ===
