# === Legacy CL2 MariaDB (read-only, for historical migration only) ===
LEGACY_DATABASE_HOST=34.28.63.124
LEGACY_DATABASE_NAME=prototipo
LEGACY_DATABASE_USER=
LEGACY_DATABASE_PASSWORD=

# === Worker ===
