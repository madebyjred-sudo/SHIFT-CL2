# Shift CL2 — environment template
# Copy to .env.local for local dev, set in Railway for prod

# === Supabase (project: shift-cl2-prod) ===
NEXT_PUBLIC_SUPABASE_URL=https://romccykiucfltfdfatrx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Cerebro (Railway shared instance, tenant=cl2) ===
CEREBRO_BASE_URL=https://shift-cerebro.up.railway.app
CEREBRO_TENANT=cl2
CEREBRO_API_KEY=
# Toggle the fire-and-forget hand-off from CL2 chat to Cerebro's Peaje
# flywheel (institutional insight extraction → Punto Medio). Set to 'false'
# during a Cerebro outage to silence the warn logs without redeploying.
PEAJE_ENABLED=true

# === LLM router (OpenRouter via Cerebro) ===
OPENROUTER_API_KEY=

# === Transcription / TTS (ElevenLabs) ===
# Used by /api/podcasts pipeline. Same key serves transcription + TTS.
ELEVENLABS_API_KEY=
# Whitelisted voice IDs the podcast modal exposes to the user.
# Defaults are popular ES-friendly multilingual voices from the public library.
PODCAST_VOICE_HOST_ID=EXAVITQu4vr4xnSDxMAY
PODCAST_VOICE_GUEST_ID=JBFqnCBsd6RMkjVDRZzb
# GCS bucket for generated mp3s. Hand-create before first use.
PODCAST_GCS_BUCKET=shift-cl2-podcasts

# === Document generation ===
GAMMA_API_KEY=

# === GCP (Storage + Vertex AI embeddings) ===
# SA needs roles: storage.objectViewer (buckets) + aiplatform.user (Vertex)
GOOGLE_APPLICATION_CREDENTIALS=./infra/secrets/gcp-sa.json
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# Vertex AI embeddings (RAG over transcripts)
# gemini-embedding-001 = 3072d multilingual, matches pgvector schema
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_EMBEDDING_DIM=3072

# GCS buckets (legacy CL2 audio/transcripts)
GCS_BUCKET_AUDIO=sesiones-asamblea-plenario-uc1
GCS_BUCKET_TRANSCRIPTS=sesiones-transcripciones-uc1
# SIL document mirror (PDFs from asamblea.go.cr — created in D2)
# SA needs storage.objectAdmin on this bucket (write).
GCS_BUCKET_SIL=shift-cl2-sil

# === SIL crawler endpoints (override only if upstream relocates) ===
SIL_SHAREPOINT_BASE=https://www.asamblea.go.cr/glcp
SIL_WEBFORMS_BASE=https://consultassil3.asamblea.go.cr

# === Legacy CL2 MariaDB (read-only, for historical migration only) ===
LEGACY_DATABASE_HOST=34.28.63.124
LEGACY_DATABASE_NAME=prototipo
LEGACY_DATABASE_USER=
LEGACY_DATABASE_PASSWORD=

# === Transcript fetch strategy (deep fix 2026-05-28) ===
# Comma-ordered list of sources to try: ytdlp, gemini, lib
#   ytdlp  = yt-dlp subprocess (cleanest Spanish auto-captions)
#   gemini = Gemini 2.5 Flash/Pro (works from Cloud Run, quality varies)
#   lib    = youtube-transcript npm library (fast, no subprocess)
# Default: ytdlp,gemini,lib  — yt-dlp first for quality, Gemini fallback for Cloud Run.
TRANSCRIPT_FETCH_STRATEGY=ytdlp,gemini,lib

# Minimum words per minute for a transcript to be considered usable.
# Legislative Spanish ~100-150 wpm. Below 30 suggests heavy truncation/garbage.
TRANSCRIPT_MIN_WORDS_PER_MINUTE=30

# Max ratio of garbage segments ([inaudible], [conversaciones superpuestas], etc.)
TRANSCRIPT_MAX_GARBAGE_RATIO=0.30

# Enable Gemini transcript generation (requires GCP ADC or service account)
GEMINI_TRANSCRIPT_ENABLED=true
GEMINI_TRANSCRIPT_MODEL=gemini-2.5-flash
GEMINI_TRANSCRIPT_MODEL_LONG=gemini-2.5-pro

# yt-dlp anti-bot config (only needed if YouTube blocks your IP)
YT_COOKIES_PATH=
YT_PROXY_URL=

# === Worker ===
WORKER_CRON_SCHEDULE="0 */6 * * *"
PLAYWRIGHT_HEADLESS=true

# === API ===
API_PORT=3001
API_BASE_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:5173,https://alpha.agentescl2.com

# === Web ===
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:3001
