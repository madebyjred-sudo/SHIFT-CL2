{
  "name": "shift-cl2",
  "version": "0.1.0",
  "private": true,
  "description": "Shift CL2 — Legislative Intelligence Platform. Vertical 1 of cerebro-vertical template.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "seed:demo": "tsx -r dotenv/config scripts/seed-demo.ts dotenv_config_path=.env.local",
    "migrate:cl2": "tsx -r dotenv/config scripts/migrate-cl2-mariadb.ts dotenv_config_path=.env.local",
    "backfill:sil:sharepoint": "tsx -r dotenv/config scripts/backfill-sil-sharepoint.ts dotenv_config_path=.env.local",
    "backfill:sil:webforms": "tsx -r dotenv/config scripts/backfill-sil-webforms.ts dotenv_config_path=.env.local"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.46.0",
    "@types/node": "^22.9.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google-cloud/aiplatform": "^6.6.0",
    "openai": "^6.34.0"
  }
}
